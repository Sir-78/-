.container {
  padding: 20rpx;
  background-color: #f5f5f5;
}

/* 路线标题样式 */
.route-header {
  margin-bottom: 30rpx;
  border-bottom: 1px solid #eee;
  padding-bottom: 20rpx;
}

.route-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  display: block;
}

.route-meta {
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
  color: #666;
}

/* 路线详情样式 */
.route-details {
  margin-bottom: 30rpx;
  background-color: #fff;
  padding: 20rpx;
  border-radius: 8rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  animation: fade-in-up 400ms ease both;
}

.detail-item {
  margin-bottom: 15rpx;
}

.detail-label {
  font-weight: bold;
  color: #333;
  margin-right: 10rpx;
}

.detail-value {
  color: #666;
}

/* 评分和评论区域样式 */
.rating-section {
  margin-bottom: 30rpx;
  border-top: 1px solid #eee;
  padding-top: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.rating-stars {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.stars {
  display: flex;
  margin-left: 20rpx;
}

.star {
  font-size: 40rpx;
  color: #ddd;
  margin-right: 10rpx;
}

.star.active {
  color: #f5a623;
}

.comment-area textarea {
  width: 100%;
  height: 200rpx;
  border: 1px solid #ddd;
  border-radius: 8rpx;
  padding: 10rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.submit-btn {
  background: linear-gradient(135deg, #6EE7F9 0%, #33CC99 100%);
  color: #fff;
  border-radius: 8rpx;
  font-size: 28rpx;
  width: 200rpx;
  box-shadow: 0 8rpx 24rpx rgba(51, 204, 153, 0.3);
  transition: all 0.3s ease;
}

.submit-btn:active {
  transform: scale(0.98);
  box-shadow: 0 12rpx 32rpx rgba(51, 204, 153, 0.4);
}

/* 相关路线推荐样式 */
.related-routes {
  margin-top: 30rpx;
  border-top: 1px solid #eee;
  padding-top: 20rpx;
}

.route-list {
  display: flex;
  flex-direction: column;
}

.route-item {
  padding: 20rpx;
  border-bottom: 1px solid #eee;
  background-color: #fff;
  margin-bottom: 15rpx;
  border-radius: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  animation: fade-in-up 400ms ease both;
}

@keyframes fade-in-up {
  0% { opacity: 0; transform: translateY(10rpx); }
  100% { opacity: 1; transform: translateY(0); }
}

.route-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  display: block;
}

.route-brief {
  font-size: 26rpx;
  color: #666;
}
