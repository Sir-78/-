/* pages/index/index.wxss */

/* 搜索栏样式 */
.search-bar {
  padding: 20rpx;
  background-color: #ffffff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 30rpx;
  padding: 10rpx 20rpx;
}

.search-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 10rpx;
}

.search-input {
  flex: 1;
  height: 60rpx;
  font-size: 28rpx;
}

/* 轮播图样式 */
.banner-section {
  margin-bottom: 20rpx;
}

.banner {
  height: 300rpx;
  width: 100%;
}

.banner-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}
.banner-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 20rpx;
  background: linear-gradient(135deg, #A5F3FC 0%, #22C55E 100%);
}
.banner-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}
.banner-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
}

/* 导航菜单样式 */
.nav-section {
  display: flex;
  justify-content: space-between;
  padding: 20rpx;
  background-color: #ffffff;
  border-radius: 12rpx;
  margin: 0 20rpx 20rpx;
  box-shadow: var(--shadow);
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 20%;
}

.nav-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 10rpx;
}

.nav-text {
  font-size: 24rpx;
  color: var(--text-color);
}

/* 内容区块样式 */
.section {
  margin: 0 20rpx 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.section-badge {
  margin-left: 12rpx;
  font-size: 22rpx;
  color: #fff;
  background: linear-gradient(135deg, #A5F3FC 0%, #22C55E 100%);
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--text-color);
  position: relative;
  padding-left: 20rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 30rpx;
  background-color: var(--primary-color);
  border-radius: 4rpx;
}

.view-more {
  font-size: 24rpx;
  color: var(--text-color-lighter);
}

/* 路线卡片样式 */
.route-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.route-card {
  display: flex;
  background-color: #ffffff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: var(--shadow);
}

.route-image {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
}
.route-image-placeholder {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FDE68A 0%, #F59E0B 100%);
}
.route-placeholder-text {
  font-size: 26rpx;
  color: #fff;
  text-align: center;
  padding: 0 10rpx;
}

.route-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
}

.route-name {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-color);
  margin-bottom: 10rpx;
}

.route-meta {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: var(--text-color-light);
  margin-bottom: 15rpx;
}

.route-tags {
  display: flex;
  flex-wrap: wrap;
}

.route-tag {
  font-size: 22rpx;
  color: var(--primary-color);
  background-color: var(--primary-light);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-right: 10rpx;
  margin-bottom: 10rpx;
}

/* 社区帖子样式 */
.post-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.post-card {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: var(--shadow);
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.post-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 15rpx;
}

.post-author {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-color);
}

.post-content {
  font-size: 28rpx;
  color: var(--text-color);
  line-height: 1.5;
  margin-bottom: 15rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

.post-images {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 15rpx;
}

.post-image {
  width: 220rpx;
  height: 220rpx;
  border-radius: 8rpx;
}

.post-image.single-image {
  width: 400rpx;
  height: 300rpx;
}
.route-map {
  width: 100%;
  height: 500rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06);
}
.map-filter {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin: 20rpx;
}
.map-actions {
  position: relative;
  display: flex;
  justify-content: flex-end;
  margin: 10rpx 20rpx 0 20rpx;
}
.btn-primary {
  background: linear-gradient(135deg, #A5F3FC 0%, #22C55E 100%);
  color: #fff;
  border-radius: 30rpx;
}
.filter-chip {
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #333;
  background-color: #f5f5f5;
  transition: all 0.2s ease;
}
.filter-chip.active {
  color: #fff;
  background: linear-gradient(135deg, #93C5FD 0%, #22C55E 100%);
  box-shadow: 0 6rpx 16rpx rgba(34, 197, 94, 0.25);
}

.post-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.post-stats {
  display: flex;
  gap: 20rpx;
}

.stat-item {
  display: flex;
  align-items: center;
}

.stat-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.stat-count {
  font-size: 24rpx;
  color: var(--text-color-lighter);
}

.post-time {
  font-size: 24rpx;
  color: var(--text-color-lighter);
}
/* rich color enhancements */
.container {
  background: linear-gradient(180deg, #F0F9FF 0%, #FFFFFF 50%, #FFF5F7 100%);
  min-height: 100vh;
}
.search-bar {
  background: linear-gradient(135deg, #A5F3FC 0%, #22C55E 100%);
}
.search-input-wrapper {
  background-color: rgba(255,255,255,0.9);
}
.banner-section {
  margin: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}
.nav-section {
  background: linear-gradient(135deg, #FDE68A 0%, #F59E0B 100%);
  color: #fff;
}
.nav-icon {
  filter: drop-shadow(0 6rpx 10rpx rgba(0,0,0,0.15));
}
.nav-text {
  color: #fff;
}
.section-title {
  background: linear-gradient(90deg, #22C55E 0%, #06B6D4 50%, #F59E0B 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}
.route-card {
  position: relative;
  animation: fade-in-up 400ms ease both;
}
.route-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: linear-gradient(180deg, #3B82F6 0%, #22C55E 100%);
}
.route-card.cat-nature::before { background: linear-gradient(180deg, #22C55E 0%, #16A34A 100%); }
.route-card.cat-river::before { background: linear-gradient(180deg, #06B6D4 0%, #0EA5E9 100%); }
.route-card.cat-red::before { background: linear-gradient(180deg, #EF4444 0%, #DC2626 100%); }
.route-card.cat-rural::before { background: linear-gradient(180deg, #F59E0B 0%, #F97316 100%); }
.route-card.cat-snow::before { background: linear-gradient(180deg, #6366F1 0%, #7C3AED 100%); }
.route-card.cat-desert::before { background: linear-gradient(180deg, #FDE68A 0%, #F59E0B 100%); }
.route-card.cat-other::before { background: linear-gradient(180deg, #CBD5E1 0%, #64748B 100%); }
.post-card {
  animation: fade-in-up 400ms ease both;
}
.post-image {
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}
.nav-section,
.section,
.route-card,
.post-card {
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.nav-section:active,
.route-card:active,
.post-card:active {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 32rpx rgba(0,0,0,0.12);
}
@keyframes fade-in-up {
  0% { opacity: 0; transform: translateY(10rpx); }
  100% { opacity: 1; transform: translateY(0); }
}
