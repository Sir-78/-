<!--pages/index/index.wxml-->
<view class="container">
  <!-- 顶部搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrapper">
      <image class="search-icon" src="/images/icons/search.svg" mode="aspectFit"></image>
      <input class="search-input" placeholder="搜索路线、景点" confirm-type="search" bindconfirm="onSearch" value="{{searchKeyword}}" bindinput="onSearchInput" />
    </view>
  </view>

  <!-- 轮播图 -->
  <view class="banner-section">
    <swiper class="banner" indicator-dots="true" autoplay="true" interval="3000" duration="500" circular="true" indicator-color="rgba(255, 255, 255, 0.6)" indicator-active-color="#ffffff">
      <swiper-item wx:for="{{banners}}" wx:key="id">
        <image wx:if="{{item.imageUrl}}" src="{{item.imageUrl}}" mode="aspectFill" class="banner-image" bindtap="onBannerTap" data-id="{{item.id}}" data-type="{{item.type}}"></image>
        <view wx:else class="banner-placeholder" bindtap="onBannerTap" data-id="{{item.id}}" data-type="{{item.type}}">
          <text class="banner-title">{{item.title}}</text>
          <text class="banner-sub">{{item.subTitle}}</text>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 功能导航 -->
  <view class="nav-section">
    <view class="nav-item" wx:for="{{navItems}}" wx:key="id" bindtap="onNavTap" data-type="{{item.type}}" data-url="{{item.url}}">
      <image class="nav-icon" src="{{item.icon}}" mode="aspectFit"></image>
      <text class="nav-text">{{item.text}}</text>
    </view>
  </view>

  <!-- 推荐路线 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">热门路线</text><text class="section-badge">{{popularRoutes.length}}</text>
      <text class="view-more" bindtap="viewMoreRoutes">查看更多 ></text>
    </view>
    <view class="route-list">
      <view class="route-card cat-{{item.categoryKey}}" wx:for="{{popularRoutes}}" wx:key="id" bindtap="goToRouteDetail" data-id="{{item.id}}">
        <block wx:if="{{item.imageUrl}}">
          <image class="route-image" src="{{item.imageUrl}}" mode="aspectFill"></image>
        </block>
        <block wx:else>
          <view class="route-image-placeholder">
            <text class="route-placeholder-text">{{item.name}}</text>
          </view>
        </block>
        <view class="route-info">
          <text class="route-name">{{item.name}}</text>
          <view class="route-meta">
            <text class="route-city">{{item.city}}</text>
            <text class="route-duration">{{item.duration}}</text>
          </view>
          <view class="route-tags">
            <text class="route-tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 路线地图 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">路线地图</text>
    </view>
    <map class="route-map" latitude="{{mapCenter.latitude}}" longitude="{{mapCenter.longitude}}" scale="{{mapScale}}" markers="{{mapMarkers}}" show-location="false" bindmarkertap="onMarkerTap"></map>
    <view class="map-actions">
      <button class="btn-primary" size="mini" bindtap="locateMe">定位我</button>
    </view>
    <view class="map-filter">
      <view class="filter-chip {{selectedCategory==='all'?'active':''}}" bindtap="setCategoryFilter" data-cat="all">全部</view>
      <view class="filter-chip {{selectedCategory===item.name?'active':''}}" wx:for="{{categories}}" wx:key="name" bindtap="setCategoryFilter" data-cat="{{item.name}}">{{item.name}}（{{item.count}}）</view>
    </view>
  </view>

  <!-- 热门社区 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">社区精选</text><text class="section-badge">{{popularPosts.length}}</text>
      <text class="view-more" bindtap="viewMorePosts">查看更多 ></text>
    </view>
    <view class="post-list">
      <view class="post-card" wx:for="{{popularPosts}}" wx:key="id" bindtap="goToPostDetail" data-id="{{item.id}}">
        <view class="post-header">
          <image class="post-avatar" src="{{item.avatar}}" mode="aspectFill"></image>
          <text class="post-author">{{item.author}}</text>
        </view>
        <text class="post-content">{{item.content}}</text>
        <view class="post-images" wx:if="{{item.images.length > 0}}">
          <image 
            class="post-image {{item.images.length === 1 ? 'single-image' : ''}}" 
            wx:for="{{item.images}}" 
            wx:for-item="image" 
            wx:key="*this" 
            src="{{image}}" 
            mode="aspectFill"
          ></image>
        </view>
        <view class="post-footer">
          <view class="post-stats">
            <view class="stat-item">
              <text class="stat-icon">👍</text>
              <text class="stat-count">{{item.likes}}</text>
            </view>
            <view class="stat-item">
              <text class="stat-icon">💬</text>
              <text class="stat-count">{{item.comments}}</text>
            </view>
          </view>
          <text class="post-time">{{item.time}}</text>
        </view>
      </view>
    </view>
  </view>
  
</view>
