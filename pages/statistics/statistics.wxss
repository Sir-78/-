/* pages/statistics/statistics.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 数据概览样式 */
.data-summary {
  display: flex;
  justify-content: space-between;
  padding: 30rpx 20rpx;
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  flex-wrap: wrap;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 25%;
  margin-bottom: 10rpx;
}

.summary-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #4CAF50;
  margin-bottom: 10rpx;
}

.summary-label {
  font-size: 24rpx;
  color: #666;
}

/* 筛选区域样式 */
.filter-section {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  flex-wrap: wrap;
}

.custom-range {
  display: flex;
  width: 100%;
  margin-top: 10rpx;
}

.custom-picker {
  flex: 1;
  padding: 10rpx 20rpx;
  margin-right: 10rpx;
  border-radius: 30rpx;
  background-color: #f8f8f8;
  font-size: 24rpx;
  color: #666;
}

.filter-label {
  font-size: 28rpx;
  color: #333;
  margin-right: 20rpx;
  margin-bottom: 10rpx;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
}

.filter-option {
  font-size: 26rpx;
  color: #666;
  padding: 10rpx 20rpx;
  margin-right: 15rpx;
  margin-bottom: 10rpx;
  border-radius: 30rpx;
  background-color: #f1f1f1;
  transition: all 0.3s ease;
}

.filter-option.active {
  background-color: #4CAF50;
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.3);
}

/* 图表区域样式 */
.chart-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
  overflow: hidden;
  animation: fade-in-up 400ms ease both;
}

.chart-card:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.12);
}

.chart-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.chart-description {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 20rpx;
}

.ec-canvas {
  width: 100%;
  height: 400rpx;
  display: block;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  transition: all 0.3s ease;
}

/* 图例样式 */
.legend {
  display: flex;
  flex-wrap: wrap;
  margin-top: 20rpx;
  padding-top: 15rpx;
  border-top: 1rpx dashed #eee;
}

.legend-item {
  display: flex;
  align-items: center;
  margin-right: 30rpx;
  margin-bottom: 10rpx;
}

.legend-color {
  width: 20rpx;
  height: 20rpx;
  border-radius: 4rpx;
  margin-right: 8rpx;
}

.legend-text {
  font-size: 24rpx;
  color: #666;
}

/* 排行榜样式 */
.list {
  margin-top: 20rpx;
}

.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.list-item:last-child {
  border-bottom: none;
}

.flex {
  display: flex;
}

.align-center {
  align-items: center;
}

.rank-number {
  width: 50rpx;
  height: 50rpx;
  line-height: 50rpx;
  text-align: center;
  background-color: #f1f1f1;
  color: #666;
  border-radius: 50%;
  font-size: 26rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.top-rank {
  color: #fff;
}

.rank-number.top-rank:nth-child(1) {
  background: linear-gradient(135deg, #FFE082 0%, #FFD54F 100%);
}

.rank-number.top-rank:nth-child(2) {
  background: linear-gradient(135deg, #E0E0E0 0%, #BDBDBD 100%);
}

.rank-number.top-rank:nth-child(3) {
  background: linear-gradient(135deg, #E6A57E 0%, #D48F6A 100%);
}

.route-name {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 400rpx;
}

.booking-count {
  font-size: 24rpx;
  color: #4CAF50;
  font-weight: 500;
}

/* 空状态提示 */
.empty-chart {
  height: 200rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #999;
  font-size: 28rpx;
}

/* 加载中提示 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 255, 255, 0.7);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #f3f3f3;
  border-top: 6rpx solid #4CAF50;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

@keyframes fade-in-up {
  0% { opacity: 0; transform: translateY(10rpx); }
  100% { opacity: 1; transform: translateY(0); }
}
