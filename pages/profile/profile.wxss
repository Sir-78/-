/* pages/profile/profile.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 30rpx;
}

/* 顶部标题栏 */
.header {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #f5f5f5;
  position: relative;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

/* 用户信息区域 */
.user-info-section {
  padding: 30rpx;
  background-color: #fff;
  border-radius: 20rpx 20rpx 0 0;
  margin-top: 20rpx;
  display: flex;
  align-items: center;
}

.user-avatar-container {
  margin-right: 30rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

.user-details {
  flex: 1;
}

.user-nickname {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.login-placeholder {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.login-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.login-btn {
  background: linear-gradient(135deg, #6EE7F9 0%, #33CC99 100%);
  color: #fff;
  font-size: 28rpx;
  padding: 10rpx 60rpx;
  border-radius: 30rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(51, 204, 153, 0.3);
  transition: all 0.3s ease;
}

.login-btn::after {
  border: none;
}

.login-btn:active {
  transform: scale(0.98);
  box-shadow: 0 12rpx 32rpx rgba(51, 204, 153, 0.4);
}

/* 数据统计区域 */
.stats-section {
  display: flex;
  justify-content: space-around;
  padding: 30rpx;
  background-color: #f5f5f5;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.stat-label {
  font-size: 28rpx;
  color: #666;
  margin-top: 10rpx;
}

/* 订单区域 */
.orders-section {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  margin-top: 20rpx;
}

.order-card {
  width: 48%;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  position: relative;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  animation: fade-in-up 400ms ease both;
}

.order-card:active {
  transform: scale(0.99);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.12);
}
.order-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.order-count {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 30rpx;
}

.view-btn {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  font-size: 26rpx;
  color: #fff;
  background-color: #ff9800;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
}

.order-card.scenic {
  background-color: #e8f5e9;
}

.order-card.travel {
  background-color: #fff8e1;
}

/* 服务区域 */
.services-section {
  margin-top: 30rpx;
  padding: 30rpx;
  background-color: #fff;
  border-radius: 16rpx 16rpx 0 0;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  animation: fade-in-up 400ms ease both;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 30rpx 20rpx;
}

.service-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: fade-in-up 400ms ease both;
}

.service-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 36rpx;
  color: #fff;
}

.service-icon.money {
  background: linear-gradient(135deg, #A5F3FC 0%, #22C55E 100%);
}

.service-icon.travel {
  background: linear-gradient(135deg, #93C5FD 0%, #3B82F6 100%);
}

.service-icon.invite {
  background: linear-gradient(135deg, #FDE68A 0%, #F59E0B 100%);
}

.service-icon.faq {
  background: linear-gradient(135deg, #E9D5FF 0%, #8B5CF6 100%);
}

.service-icon.privacy {
  background: linear-gradient(135deg, #FCA5A5 0%, #EF4444 100%);
}

.service-icon.service {
  background: linear-gradient(135deg, #99F6E4 0%, #06B6D4 100%);
}

.service-icon.logout {
  background: linear-gradient(135deg, #CBD5E1 0%, #475569 100%);
}

.service-name {
  font-size: 24rpx;
  color: #666;
  text-align: center;
}

.view-more-btn {
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #4CAF50;
  border-top: 1rpx dashed #eee;
  margin-top: 10rpx;
  text-align: center;
}

/* 帖子列表 */
.post-list {
  max-height: 800rpx;
  overflow-y: auto;
}

.post-item {
  display: flex;
  flex-direction: column;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
  animation: fade-in-up 400ms ease both;
}

.post-info {
  flex: 1;
  margin-bottom: 16rpx;
}

.post-content {
  font-size: 28rpx;
  margin-bottom: 10rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.post-date {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 8rpx;
}

.post-stats {
  display: flex;
  justify-content: flex-end;
}

.post-likes, .post-comments {
  display: flex;
  align-items: center;
  margin-left: 20rpx;
}

.like-count, .comment-count {
  font-size: 26rpx;
  font-weight: bold;
  color: #666;
  margin-right: 4rpx;
}

.like-text, .comment-text {
  font-size: 24rpx;
  color: #999;
}

/* 空列表提示 */
.empty-list {
  padding: 40rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.empty-action {
  margin-top: 20rpx;
}

.empty-action navigator {
  display: inline-block;
  color: #4CAF50;
  font-size: 26rpx;
  padding: 10rpx 30rpx;
  border: 1rpx solid #4CAF50;
  border-radius: 30rpx;
}

/* 设置区域 */
.menu-section {
  margin-bottom: 20rpx;
}

.settings-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 0 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  animation: fade-in-up 400ms ease both;
}

.settings-item {
  display: flex;
  align-items: center;
  padding: 30rpx 20rpx;
  border-bottom: 1rpx solid #eee;
}

.settings-item:last-child {
  border-bottom: none;
}

.settings-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.settings-text {
  font-size: 30rpx;
  flex: 1;
}

.settings-arrow {
  color: #999;
  font-size: 24rpx;
}

/* 底部版本信息 */
.footer {
  text-align: center;
  padding: 40rpx 0;
}

.version {
  font-size: 24rpx;
  color: #999;
}

/* 加载中提示 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 255, 255, 0.7);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #f3f3f3;
  border-top: 6rpx solid #4CAF50;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

@keyframes fade-in-up {
  0% { opacity: 0; transform: translateY(10rpx); }
  100% { opacity: 1; transform: translateY(0); }
}
