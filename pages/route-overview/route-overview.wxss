.container {
  padding: 20rpx;
  background-color: #f5f5f5;
}

.map-section {
  margin-bottom: 20rpx;
}
.route-map {
  width: 100%;
  height: 500rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06);
}
.map-filter {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
}
.filter-chip {
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #333;
  background-color: #f5f5f5;
  transition: all 0.2s ease;
}
.filter-chip.active {
  color: #fff;
  background: linear-gradient(135deg, #93C5FD 0%, #22C55E 100%);
  box-shadow: 0 6rpx 16rpx rgba(34, 197, 94, 0.25);
}
.map-actions {
  position: relative;
  display: flex;
  justify-content: flex-end;
  margin-top: 10rpx;
}
.btn-primary {
  background: linear-gradient(135deg, #A5F3FC 0%, #22C55E 100%);
  color: #fff;
  border-radius: 30rpx;
}

.route-summary {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.9) 30%, rgba(255,255,255,1) 100%);
}
.summary-card {
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.08);
  padding: 20rpx;
}
.summary-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}
.cat-tag {
  display: inline-block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #fff;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}
.cat-nature { background: linear-gradient(135deg, #22C55E 0%, #16A34A 100%); }
.cat-river { background: linear-gradient(135deg, #06B6D4 0%, #0EA5E9 100%); }
.cat-red { background: linear-gradient(135deg, #EF4444 0%, #DC2626 100%); }
.cat-rural { background: linear-gradient(135deg, #F59E0B 0%, #F97316 100%); }
.cat-snow { background: linear-gradient(135deg, #6366F1 0%, #7C3AED 100%); }
.cat-desert { background: linear-gradient(135deg, #FDE68A 0%, #F59E0B 100%); }
.cat-other { background: linear-gradient(135deg, #CBD5E1 0%, #64748B 100%); }
.summary-meta {
  display: flex;
  gap: 20rpx;
  margin: 10rpx 0 6rpx;
}
.meta-item {
  font-size: 24rpx;
  color: #666;
}
.summary-desc {
  font-size: 26rpx;
  color: #444;
  margin: 10rpx 0 16rpx;
}
.summary-actions {
  display: flex;
  gap: 16rpx;
}
.btn-primary {
  background: linear-gradient(135deg, #A5F3FC 0%, #22C55E 100%);
  color: #fff;
  border-radius: 30rpx;
}
.btn-secondary {
  background-color: #f5f5f5;
  color: #333;
  border-radius: 30rpx;
}

.header {
  text-align: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1px solid #eee;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
}

/* 分类卡片样式 */
.category-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.category-card {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  animation: fade-in-up 400ms ease both;
}

.category-card:active {
  transform: scale(0.99);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.12);
}

.category-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 16rpx;
  border-radius: 10rpx;
}

.category-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
}

.category-count {
  font-size: 26rpx;
  color: #fff;
  background-color: rgba(0,0,0,0.15);
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
}

.category-content {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.content-section {
  margin-bottom: 10rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  display: block;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  font-size: 24rpx;
  color: #666;
  background-color: #f0f0f0;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 路线列表样式 */
.route-list {
  margin-top: 30rpx;
  padding-top: 20rpx;
}

.route-list-header {
  margin-bottom: 20rpx;
}

.route-list-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.route-item {
  background-color: #fff;
  border: none;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
  animation: fade-in-up 400ms ease both;
}

.route-item:active {
  transform: translateY(-2rpx);
  box-shadow: 0 10rpx 28rpx rgba(0, 0, 0, 0.12);
}

.route-item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
  padding-bottom: 10rpx;
}

.route-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.route-duration {
  font-size: 24rpx;
  color: #666;
  background-color: #e8f5e9;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

@keyframes fade-in-up {
  0% { opacity: 0; transform: translateY(10rpx); }
  100% { opacity: 1; transform: translateY(0); }
}

.category-card.desert .category-header {
  background: linear-gradient(135deg, #FDE68A 0%, #F59E0B 100%);
}
.category-card.mountain .category-header {
  background: linear-gradient(135deg, #93C5FD 0%, #3B82F6 100%);
}
.category-card.red .category-header {
  background: linear-gradient(135deg, #FCA5A5 0%, #EF4444 100%);
}
.category-card.rural .category-header {
  background: linear-gradient(135deg, #A7F3D0 0%, #10B981 100%);
}
.category-card.river .category-header {
  background: linear-gradient(135deg, #A5F3FC 0%, #06B6D4 100%);
}
.category-card.snow .category-header {
  background: linear-gradient(135deg, #E0E7FF 0%, #6366F1 100%);
}

.route-item-content {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.route-info {
  display: flex;
  font-size: 26rpx;
  line-height: 1.5;
}

.info-label {
  color: #666;
  min-width: 150rpx;
}

.info-value {
  color: #333;
  flex: 1;
}
